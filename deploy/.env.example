# Copy to .env and adjust. Never commit real secrets.

# --- GROBID service ---
# crf-lite (default, multi-arch) or set the DL image for dl-parity profile.
GROBID_IMAGE=grobid/grobid:0.9.0-crf
GROBID_DL_IMAGE=grobid/grobid:0.9.0-full
GROBID_URL=http://grobid:8070

# --- consolidation (reference matching) ---
# Local glutton (needs the glutton-local profile + the prebuilt DB; see README > Consolidation).
# The public cloud glutton is only a rate-limited demo and its TLS cert can be rejected by
# GROBID's JVM, so it isn't a supported path here.
GLUTTON_URL=http://glutton:8080
# GROBID's published PMC/bioRxiv/PLOS numbers come from consolidateHeader=1 + consolidateCitations=0
# (see grobid-trainer EndToEndEvaluation). Keep that flow for apples-to-apples scores:
#   - CONSOLIDATE_HEADER=1 enriches paper-level metadata via glutton (needs the service reachable).
#   - CONSOLIDATE_CITATIONS=0 leaves parsed references as-is. Turning it on (1=replace, 2=DOI-only)
#     swaps in full-precision CrossRef fields (e.g. a full date vs the year-only JATS gold), which
#     the scorer compares verbatim and which *deflates* citation scores. For a fully offline
#     baseline (no glutton), set both to 0.
CONSOLIDATE_HEADER=1
CONSOLIDATE_CITATIONS=0
# LLM-side consolidation (same glutton service, symmetric to GROBID). Unset = mirror the GROBID
# flags above, so a scored run treats both tools identically. Set explicitly only to demo the LLM's
# DOI-enrichment path (mode 1 replaces fields incl. full CrossRef dates; 2 = identifiers only).
# LLM_CONSOLIDATE_HEADER=1
# LLM_CONSOLIDATE_CITATIONS=0

# Local glutton (only for the glutton-local profile). biblio-glutton has no published image, so
# build the shadow jar from source (kermitt2/biblio-glutton, ./gradlew shadowJar) and point
# GLUTTON_JAR at it. GLUTTON_CONFIG is the glutton.yml (elastic.host=elasticsearch:9200,
# grobidHost=http://grobid:8070/api). GLUTTON_DB_DIR holds the LMDB stores (crossref/pmid/...),
# GLUTTON_INDEX_DIR the prebuilt ES data dir (chowned to uid 1000).
GLUTTON_DB_DIR=./glutton/data/db
GLUTTON_INDEX_DIR=./glutton/index
GLUTTON_JAR=./glutton/lookup-service.jar
GLUTTON_CONFIG=./glutton/glutton.yml
GLUTTON_RUNTIME_IMAGE=eclipse-temurin:11-jre

# --- run scope ---
# The benchmark targets the full dataset. N_ARTICLES=1943 runs the complete
# PMC_sample_1943 set (GROBID's published benchmark). Lower it for a quick sample.
DATASET=PMC_sample_1943
N_ARTICLES=1943
# 1 = reproduce GROBID baseline only (no LLM key needed); 0 = also run + score the LLM.
BASELINE_ONLY=1

# --- LLM backend (only used when BASELINE_ONLY=0) ---
LLM_BACKEND=azure
LLM_MODEL=gpt-4o
# Optional: namespace this run's TEI as *.fulltext.llm.<tag>.tei.xml and name its report,
# so multiple backends can coexist in the same data volume and be compared separately.
LLM_TAG=
LLM_REPORT=llm_report.md

# Azure OpenAI (set your own values in .env, not here):
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# Generic OpenAI-compatible endpoint (LLM_BACKEND=openai):
OPENAI_API_KEY=
OPENAI_BASE_URL=

# --- GPU (dl-parity profile) ---
# GPU is enabled via the docker-compose.gpu.yml override on a host with the NVIDIA runtime.
